# Copy to `.env.local` and fill from Supabase: Project Settings → API
# New project: create the project, then paste URL, anon (public) key, and service_role key.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Public app URL used for metadata, links, and callbacks.
# Example: https://your-project.vercel.app
NEXT_PUBLIC_APP_URL=

# DPOPay scaffold variables (required when enabling live integration).
DPOPAY_COMPANY_TOKEN=
DPOPAY_SERVICE_TYPE=
DPOPAY_WEBHOOK_SECRET=
