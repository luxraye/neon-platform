# Copy to `.env.local` and fill from Supabase: Project Settings → API
# New project: create the project, then paste URL, anon (public) key, and service_role key.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Public app URL used for metadata, links, and callbacks.
# Example: https://your-project.vercel.app
NEXT_PUBLIC_APP_URL=

# Resend (transactional email — signup addresses). https://resend.com
RESEND_API_KEY=
# Verified sender, e.g. Neon <notifications@yourdomain.com>
RESEND_FROM=

# Protect /api/cron/notifications (set in Vercel env; Vercel Cron sends Authorization: Bearer <CRON_SECRET> if configured).
CRON_SECRET=

# DPOPay scaffold variables (required when enabling live integration).
DPOPAY_COMPANY_TOKEN=
DPOPAY_SERVICE_TYPE=
DPOPAY_WEBHOOK_SECRET=
